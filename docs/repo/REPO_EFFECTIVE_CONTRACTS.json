      {
        "key": "public.lock_events",
        "source_path": "supabase/migrations/20260402003302_lock_events_function.sql",
        "value": {
          "name": {
            "raw": "public.lock_events",
            "qualified_name": "public.lock_events",
            "schema": "public",
            "name": "lock_events"
          },
          "arguments_literal": "limit_count integer default 10",
          "returns_literal": "setof events",
          "language": "sql",
          "security": "invoker",
          "source_path": "supabase/migrations/20260402003302_lock_events_function.sql",
          "literal_sql_header": "create or replace function public.lock_events(limit_count integer default 10)\nreturns setof events\nlanguage sql\nsecurity invoker\nas $$\n  update events\n  set status = 'processing'\n  where id in (\n    select id\n    from events\n    where status = 'pending'\n      and (next_retry_at is null or next_retry_at <= now())\n    order by created_at asc\n    limit limit_count\n    for update skip locked\n  )\n  returning *;"
        },
        "override_count": 0,
        "history_source_paths": [
          "supabase/migrations/20260402003302_lock_events_function.sql"
        ]
      }
